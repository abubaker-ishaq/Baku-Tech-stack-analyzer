{
  "name": "firebase-llm-cost-optimizer-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for LLM Cost Optimization using Google Gen AI SDK",
  "main": "lib/index.js",
  "scripts": {
    "lint": "tslint --project tsconfig.json",
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions"
  },
  "engines": {
    "node": "18"
  },
  "dependencies": {
    "@google/genai": "^0.1.1",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "firebase-functions-test": "^3.1.0"
  },
  "private": true
}
